{
  "_version": "1.83.0",
  "sap.app": {
    "id": "com.mycompany.leads.leadmanagement",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.21.0",
      "toolsId": "9db56856-0fb6-40a4-aae8-6905751bfe89"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/LeadService/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "extends": {
      "extensions": {
        "sap.ui.controllerExtensions": {
          "sap.fe.templates.ListReport.ListReportController": {
            "controllerName": "com.mycompany.leads.leadmanagement.ext.controller.ListReportExt"
          }
        }
      }
    },
    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {},
        "sap.f": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.mycompany.leads.leadmanagement.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {
        "flexibleColumnLayout": {
          "defaultTwoColumnLayoutType": "TwoColumnsMidExpanded",
          "defaultThreeColumnLayoutType": "ThreeColumnsMidExpanded"
        },
        "routerClass": "sap.f.routing.Router"
      },
      "routes": [
        {
          "pattern": ":?query:",
          "name": "LeadsList",
          "target": [
            "LeadsList"
          ]
        },
        {
          "pattern": "Leads({key}):?query:",
          "name": "LeadsObjectPage",
          "target": [
            "LeadsList",
            "LeadsObjectPage"
          ]
        },
        {
          "name": "Leads_activitiesObjectPage",
          "pattern": "Leads({key})/activities({activitiesKey}):?query:",
          "target": [
            "LeadsList",
            "LeadsObjectPage",
            "Leads_activitiesObjectPage"
          ]
        }
      ],
      "targets": {
        "LeadsList": {
          "type": "Component",
          "id": "LeadsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/Leads",
              "variantManagement": "Page",
              "navigation": {
                "Leads": {
                  "detail": {
                    "route": "LeadsObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "quickVariantSelection": {
                      "showCounts": true
                    }
                  },
                  "actions": {
                    "importExcel": {
                      "press": ".extension.com.mycompany.leads.leadmanagement.ext.controller.ListReportExt.onImportExcel",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": false,
                      "text": "Import from Excel"
                    }
                  }
                }
              },
              "initialLoad": "Enabled"
            }
          },
          "controlAggregation": "beginColumnPages",
          "contextPattern": ""
        },
        "LeadsObjectPage": {
          "type": "Component",
          "id": "LeadsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/Leads",
              "navigation": {
                "activities": {
                  "detail": {
                    "route": "Leads_activitiesObjectPage"
                  }
                }
              },
              "content": {
                "header": {
                  "anchorBarVisible": true
                }
              },
              "controlConfiguration": {
                "activities/@com.sap.vocabularies.UI.v1.LineItem#Activities": {
                  "tableSettings": {
                    "creationMode": {
                      "name": "Inline"
                    }
                  }
                },
                "contacts/@com.sap.vocabularies.UI.v1.LineItem#Contacts": {
                  "tableSettings": {
                    "creationMode": {
                      "name": "Inline"
                    }
                  }
                },
                "notes/@com.sap.vocabularies.UI.v1.LineItem#Notes": {
                  "tableSettings": {
                    "creationMode": {
                      "name": "Inline"
                    }
                  }
                }
              },
              "sectionLayout": "Tabs"    
            }
          },
          "controlAggregation": "midColumnPages",
          "contextPattern": "/Leads({key})"
        },
        "Leads_activitiesObjectPage": {
          "type": "Component",
          "id": "Leads_activitiesObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "navigation": {},
              "contextPath": "/Leads/activities"
            }
          },
          "controlAggregation": "endColumnPages",
          "contextPattern": "/Leads({key})/activities({activitiesKey})"
        }
      }
    },
    "rootView": {
      "viewName": "sap.fe.templates.RootContainer.view.Fcl",
      "type": "XML",
      "async": true,
      "id": "appRootView"
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": false
    }
  }
}