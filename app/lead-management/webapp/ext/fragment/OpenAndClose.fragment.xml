<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="myDialog"
        title="Upload Details"
        draggable="true"
        resizable="true">

        <content>
            <VBox id="_IDGenVBox" class="sapUiSmallMargin">
                
                <Input
                    id="inputName"
                    placeholder="Enter Name" />

                <Input
                    id="inputEmail"
                    placeholder="Enter Email" />

            </VBox>
        </content>

        <beginButton>
            <Button
                id="uploading"
                text="Upload"
                press=".onUploadDialogInput" />
        </beginButton>

        <endButton>
            <Button
                id="cancelling"
                text="Cancel"
                press=".onCloseDialogInput" />
        </endButton>

    </Dialog>

</core:FragmentDefinition>