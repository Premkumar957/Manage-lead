<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">

    <Dialog id="_IDGenDialog1" title="Create Business Partner" class="sapUiContentPadding">
        <content>
            <f:SimpleForm id="_IDGenSimpleForm" editable="true" layout="ResponsiveGridLayout">

                <Label id="_IDGenLabel" text="Name"/>
                <Input id="_IDGenInput" value="{localModel>/BusinessPartnerFullName}" />

                <Label id="_IDGenLabel1" text="Category"/>
                <Select id="_IDGenSelect" selectedKey="{localModel>/BusinessPartnerCategory}">
                    <items>
                        <core:Item id="_IDGenItem" key="1" text="Person"/>
                        <core:Item id="_IDGenItem1" key="2" text="Organization"/>
                        <core:Item id="_IDGenItem2" key="3" text="Group"/>
                    </items>
                </Select>

                <Label id="_IDGenLabel2" text="Grouping"/>
                <Input id="_IDGenInput1" value="{localModel>/BusinessPartnerGrouping}" />

                <Label id="_IDGenLabel3" text="Industry"/>
                <Input id="_IDGenInput2" value="{localModel>/Industry}" />

                <Label id="_IDGenLabel4" text="Customer"/>
                <Switch id="_IDGenSwitch" state="{localModel>/Customer}" />

                <Label id="_IDGenLabel5" text="Supplier"/>
                <Switch id="_IDGenSwitch1" state="{localModel>/Supplier}" />

                <Label id="_IDGenLabel6" text="Blocked"/>
                <Switch id="_IDGenSwitch2" state="{localModel>/BusinessPartnerIsBlocked}" />

                <Label id="_IDGenLabel7" text="Archiving"/>
                <Switch id="_IDGenSwitch3" state="{localModel>/IsMarkedForArchiving}" />

            </f:SimpleForm>
        </content>

        <beginButton>
            <Button id="_IDGenButton" text="Create" press=".onCreateBP"/>
        </beginButton>

        <endButton>
            <Button id="_IDGenButton1" text="Cancel" press=".onCancel"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>