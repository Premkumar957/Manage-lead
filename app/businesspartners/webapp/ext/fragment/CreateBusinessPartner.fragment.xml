<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">

    <Dialog title="Create Business Partner" class="sapUiContentPadding" stretchOnPhone="true">
        <content>
            <f:SimpleForm editable="true" layout="ResponsiveGridLayout">

                <Label text="Category" required="true"/>
                <Select selectedKey="{localModel>/BusinessPartnerCategory}">
                    <items>
                        <core:Item key="1" text="Person"/>
                        <core:Item key="2" text="Organization"/>
                        <core:Item key="3" text="Group"/>
                    </items>
                </Select>

                <Label text="Grouping" required="true"/>
                <Input value="{localModel>/BusinessPartnerGrouping}" valueLiveUpdate="true"/>

                <!-- PERSON -->
                <Label text="First Name"
                       visible="{= ${localModel>/BusinessPartnerCategory} === '1' }"/>
                <Input value="{localModel>/FirstName}"
                       valueLiveUpdate="true"
                       visible="{= ${localModel>/BusinessPartnerCategory} === '1' }"/>

                <Label text="Last Name"
                       visible="{= ${localModel>/BusinessPartnerCategory} === '1' }"/>
                <Input value="{localModel>/LastName}"
                       valueLiveUpdate="true"
                       visible="{= ${localModel>/BusinessPartnerCategory} === '1' }"/>

                <!-- ORGANIZATION -->
                <Label text="Organization Name"
                       visible="{= ${localModel>/BusinessPartnerCategory} === '2' }"/>
                <Input value="{localModel>/OrganizationBPName1}"
                       valueLiveUpdate="true"
                       visible="{= ${localModel>/BusinessPartnerCategory} === '2' }"/>

                <!-- GROUP -->
                <Label text="Group Name"
                       visible="{= ${localModel>/BusinessPartnerCategory} === '3' }"/>
                <Input value="{localModel>/GroupBusinessPartnerName1}"
                       valueLiveUpdate="true"
                       visible="{= ${localModel>/BusinessPartnerCategory} === '3' }"/>

                <Label text="Language"/>
                <Select selectedKey="{localModel>/CorrespondenceLanguage}">
                    <items>
                        <core:Item key="EN" text="English"/>
                        <core:Item key="DE" text="German"/>
                        <core:Item key="FR" text="French"/>
                    </items>
                </Select>

            </f:SimpleForm>
        </content>

        <beginButton>
            <Button text="Create" press="onCreateBP"/>
        </beginButton>

        <endButton>
            <Button text="Cancel" press="onCancel"/>
        </endButton>
    </Dialog>

</core:FragmentDefinition>